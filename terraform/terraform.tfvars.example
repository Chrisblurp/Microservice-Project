# Example terraform.tfvars file - Copy to terraform.tfvars and modify as needed

environment = "production"
location    = "West Europe"  # Using West Europe region

aks_node_count = 2
aks_vm_size    = "Standard_B2s"

postgres_sku = "B_Standard_B1ms"
redis_capacity = 1

tags = {
  Environment = "Production"
  Project     = "MicroservicesPlatform"
  ManagedBy   = "Terraform"
  CostCenter  = "DevOps"
  Region      = "West Europe"
}
